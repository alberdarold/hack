# Copy this file to .env and fill in your real values.
# .env is git-ignored - never commit it, never hardcode keys in source files.

# --- LLM provider (OpenAI-compatible) ---
# You can use Regolo.ai or Mistral (both free tier, see BRIEF.md).
#   Regolo:  LLM_BASE_URL=https://api.regolo.ai/v1     (model ids are case-sensitive)
#   Mistral: LLM_BASE_URL=https://api.mistral.ai/v1
LLM_BASE_URL=https://api.regolo.ai/v1
LLM_API_KEY=
# MODEL is OPTIONAL: if left blank, the backend probes GET $LLM_BASE_URL/models
# at startup and auto-selects the first live tool-calling-capable id from its
# preference list (gpt-oss-120b, Llama-3.3-70B-Instruct, ...). Set it explicitly
# to pin a specific model (Regolo ids are case-sensitive). Inspect live ids with:
#   curl $LLM_BASE_URL/models -H "Authorization: Bearer $LLM_API_KEY"
MODEL=
# Optional fallback model used only if MODEL errors out (degraded mode).
MODEL_FALLBACK=
# Hard per-request timeout (seconds) for each LLM call, to respect the /ask ceiling.
LLM_TIMEOUT=15
# Wall-clock budget (seconds) for the whole tool-calling agent loop (< 30s ceiling).
LLM_AGENT_BUDGET=22
# Max tool-calling rounds before the loop forces a final answer.
LLM_MAX_STEPS=5

# --- Al Dente mock APIs (the company data) ---
# Your personal token is on the event platform dashboard. It authenticates AND
# identifies your calls (efficiency is measured server-side per token).
MOCK_API_BASE_URL=https://aldente.yellowtest.it
MOCK_API_TOKEN=

# --- Artifacts ---
# Public base URL of THIS backend, used to build absolute artifact_url links.
# Locally: http://localhost:8000 - on Railway: your https://....up.railway.app
# (set it on Railway right after `railway domain`, see DEPLOY.md).
PUBLIC_BASE_URL=http://localhost:8000
